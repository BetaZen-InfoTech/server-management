# =============================================================================
# ServerPanel — Development Server Environment
# This file is committed to git. Do NOT put real secrets here.
# For actual secrets, use .env (which is gitignored).
# =============================================================================

APP_ENV=development
LOG_LEVEL=debug

# MongoDB (dev server or Atlas dev cluster)
MONGO_URI=mongodb://serverpanel:CHANGE_ME@dev-server:27017/serverpanel?authSource=admin
MONGO_DB_NAME=serverpanel

# JWT
JWT_SECRET=CHANGE_ME_dev_secret_at_least_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Server
DOMAIN=dev.betazeninfotech.com
SERVER_PORT=443
TLS_CERT=/etc/letsencrypt/live/dev.betazeninfotech.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/dev.betazeninfotech.com/privkey.pem

# Agent
AGENT_PORT=8443
AGENT_API_KEY=CHANGE_ME_dev_agent_key
AGENT_TLS_CERT=/etc/serverpanel/agent.crt
AGENT_TLS_KEY=/etc/serverpanel/agent.key

# GitHub
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_WEBHOOK_SECRET=CHANGE_ME

# Email
MAIL_HOSTNAME=mail.dev.betazeninfotech.com

# Backup
BACKUP_DIR=/var/backups/serverpanel
BACKUP_ENCRYPTION_KEY=CHANGE_ME_dev_encryption_key

# Rate Limiting
RATE_LIMIT_WHM=200
RATE_LIMIT_CPANEL=100
