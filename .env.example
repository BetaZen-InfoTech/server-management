# =============================================================================
# ServerPanel Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# MongoDB (local with authentication)
# -----------------------------------------------------------------------------
# Local MongoDB: mongodb://serverpanel:YOUR_PASSWORD@127.0.0.1:27017/serverpanel?authSource=admin
# Atlas MongoDB: mongodb+srv://user:password@cluster0.example.mongodb.net/
MONGO_URI=mongodb://serverpanel:YOUR_MONGO_PASSWORD@127.0.0.1:27017/serverpanel?authSource=admin
MONGO_DB_NAME=serverpanel

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# -----------------------------------------------------------------------------
# Server (Single Domain — serves both WHM + cPanel)
# -----------------------------------------------------------------------------
DOMAIN=panel.betazeninfotech.com
SERVER_PORT=443
TLS_CERT=/etc/letsencrypt/live/panel.betazeninfotech.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/panel.betazeninfotech.com/privkey.pem

# -----------------------------------------------------------------------------
# Agent (runs on each managed VPS)
# -----------------------------------------------------------------------------
AGENT_PORT=8443
AGENT_API_KEY=change-me-to-a-random-agent-key
AGENT_TLS_CERT=/etc/serverpanel/agent.crt
AGENT_TLS_KEY=/etc/serverpanel/agent.key

# -----------------------------------------------------------------------------
# GitHub Deployment (OAuth App)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-oauth-app-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-secret
GITHUB_WEBHOOK_SECRET=your-webhook-signing-secret

# -----------------------------------------------------------------------------
# Email (Postfix hostname)
# -----------------------------------------------------------------------------
MAIL_HOSTNAME=mail.betazeninfotech.com

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_DIR=/var/backups/serverpanel
BACKUP_ENCRYPTION_KEY=change-me-to-a-random-encryption-key

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WHM=200
RATE_LIMIT_CPANEL=100
