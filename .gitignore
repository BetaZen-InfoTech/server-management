# =============================================================================
# ServerPanel — Root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment — ONLY .env is ignored (contains secrets)
# .env.local, .env.dev, .env.prod, .env.example are committed
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Go (Backend)
# -----------------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
/backend/bin/
/backend/tmp/
/backend/vendor/

# -----------------------------------------------------------------------------
# Node.js (Frontend)
# -----------------------------------------------------------------------------
node_modules/
.turbo/
dist/
.vite/
.cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Test / Coverage
# -----------------------------------------------------------------------------
coverage/
*.out
.nyc_output/

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
build/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Claude Code — settings.local.json is device-specific
# CLAUDE.md, .claude/commands/, .claude/memory.md, .claude/settings.json
# are all committed and shared via git
# -----------------------------------------------------------------------------
.claude/settings.local.json
